<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#4B6EAE</Color>
    <Color x:Key="PrimaryLight">#EAFAFF</Color>
    <Color x:Key="PrimaryDark">#00A2C9</Color>
    <Color x:Key="PrimaryDarkText">#212121</Color>
    <Color x:Key="Secondary">#C0F0FF</Color>
    <Color x:Key="SecondaryDark">#1E2C45</Color>
    <Color x:Key="SecondaryDarkText">#0089C4</Color>
    <Color x:Key="Tertiary">#99C5E4</Color>
    <Color x:Key="TertiaryDark">#145371</Color>
    <Color x:Key="Error">#FFC0D0</Color>
    <Color x:Key="ErrorDark">#700020</Color>
    <Color x:Key="Success">#40e080</Color>
    <Color x:Key="SuccessDark">#007020</Color>
    <Color x:Key="Danger">#C05060</Color>
    <Color x:Key="DangerDark">#E07080</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}" />
</ResourceDictionary>