<?xml version="1.0" encoding="utf-8" ?>
<local:RequestTemplateCollectionPageBase
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:RequestFiend.Models;assembly=RequestFiend.Models"
    xmlns:local="clr-namespace:RequestFiend.UI"
    xmlns:views="clr-namespace:RequestFiend.UI.Views"
    x:Class="RequestFiend.UI.RequestTemplatePage"
    x:DataType="models:RequestTemplateModel"
    x:TypeArguments="models:RequestTemplateModel">

    <Grid RowDefinitions="*,Auto" RowSpacing="0">
        <ScrollView>
            <VerticalStackLayout>
                <Border>
                    <VerticalStackLayout Style="{StaticResource ElementGroup}">
                        <StackLayout Orientation="{Binding StackOrientation}" HorizontalOptions="{Binding StackHorizontalOptions}">
                            <Button Text="Save changes" Clicked="OnUpdateRequestClicked"/>

                            <Button Text="Delete" Clicked="OnDeleteRequestClicked" Style="{StaticResource DangerButton}"/>
                        </StackLayout>

                        <Label Text="Name" Style="{StaticResource EntryLabel}"/>

                        <Entry Text="{Binding Name.Value}">
                            <Entry.Triggers>
                                <DataTrigger TargetType="Entry" Binding="{Binding Name.IsValid}" Value="False">
                                    <Setter Property="Background" Value="{StaticResource ErrorBackgroundBrush}" />
                                </DataTrigger>
                            </Entry.Triggers>
                        </Entry>

                        <Grid ColumnDefinitions="*,3*">
                            <Label Text="Method" Style="{StaticResource EntryLabel}"/>

                            <Label Text="Url" Style="{StaticResource EntryLabel}" Grid.Column="1"/>

                            <Picker SelectedItem="{Binding Method.Value}" ItemsSource="{x:Static models:Options.Methods}" Grid.Row="1">
                                <Picker.Triggers>
                                    <DataTrigger TargetType="Picker" Binding="{Binding Method.IsValid}" Value="False">
                                        <Setter Property="Background" Value="{StaticResource ErrorBackgroundBrush}" />
                                    </DataTrigger>
                                </Picker.Triggers>
                            </Picker>

                            <Entry Text="{Binding Url.Value}" Grid.Row="1" Grid.Column="1">
                                <Entry.Triggers>
                                    <DataTrigger TargetType="Entry" Binding="{Binding Url.IsValid}" Value="False">
                                        <Setter Property="Background" Value="{StaticResource ErrorBackgroundBrush}" />
                                    </DataTrigger>
                                </Entry.Triggers>
                            </Entry>
                        </Grid>

                        <Label Text="Headers" Style="{StaticResource SectionHeader}" SemanticProperties.HeadingLevel="Level2"/>

                        <CollectionView ItemsSource="{Binding Headers}">
                            <CollectionView.Header>
                                <Grid ColumnDefinitions="*,*,44" Style="{StaticResource Table}" IsVisible="{Binding Headers.Count, Converter={StaticResource GreaterThanZeroConverter}}">
                                    <Label Text="Name" Style="{StaticResource TableHeader}"/>

                                    <Label Text="Value" Style="{StaticResource TableHeader}" Grid.Column="1"/>
                                </Grid>
                            </CollectionView.Header>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:HeaderTemplateModel">
                                    <Grid ColumnDefinitions="*,*,44" Style="{StaticResource Table}">
                                        <Entry Text="{Binding Name.Value}" Style="{StaticResource TableEntry}">
                                            <Entry.Triggers>
                                                <DataTrigger TargetType="Entry" Binding="{Binding Name.IsValid}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource ErrorBackgroundBrush}" />
                                                </DataTrigger>
                                            </Entry.Triggers>
                                        </Entry>

                                        <Entry Text="{Binding Value.Value}" Style="{StaticResource TableEntry}" Grid.Column="1">
                                            <Entry.Triggers>
                                                <DataTrigger TargetType="Entry" Binding="{Binding Value.IsValid}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource ErrorBackgroundBrush}" />
                                                </DataTrigger>
                                            </Entry.Triggers>
                                        </Entry>

                                        <Button Text="🗙" Clicked="OnRemovetHeaderClicked" Style="{StaticResource TableButton}" Grid.Column="2" SemanticProperties.Description="Delete" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.Footer>
                                <Button Text="Add header" Clicked="OnAddHeaderClicked" Style="{StaticResource TableButton}"/>
                            </CollectionView.Footer>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <views:Message x:Name="SuccessMessage" Grid.Row="1" />
    </Grid>
</local:RequestTemplateCollectionPageBase>