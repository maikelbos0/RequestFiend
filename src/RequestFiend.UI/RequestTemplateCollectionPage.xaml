<?xml version="1.0" encoding="utf-8" ?>
<local:RequestTemplateCollectionPageBase
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:RequestFiend.UI.Models"
    xmlns:local="clr-namespace:RequestFiend.UI"
    x:Class="RequestFiend.UI.RequestTemplateCollectionPage"
    x:DataType="models:RequestTemplateCollectionModel"
    x:TypeArguments="models:RequestTemplateCollectionModel">

    <ScrollView>
        <VerticalStackLayout>

            <Border>
                <VerticalStackLayout Style="{StaticResource ElementGroup}">
                    <Label Text="Name" Style="{StaticResource FormLabel}"/>

                    <Entry Text="{Binding Name.Value}">
                        <Entry.Triggers>
                            <DataTrigger TargetType="Entry" Binding="{Binding Name.IsValid}" Value="False">
                                <Setter Property="Background" Value="{StaticResource ErrorBackgroundBrush}" />
                            </DataTrigger>
                        </Entry.Triggers>
                    </Entry>

                    <Label Text="Default url (optional)" Style="{StaticResource FormLabel}"/>

                    <Entry Text="{Binding DefaultUrl.Value}" />

                    <Button Text="Save changes" HorizontalOptions="Fill" Clicked="OnUpdateCollectionClicked"/>
                </VerticalStackLayout>
            </Border>
            
        </VerticalStackLayout>
    </ScrollView>
</local:RequestTemplateCollectionPageBase>