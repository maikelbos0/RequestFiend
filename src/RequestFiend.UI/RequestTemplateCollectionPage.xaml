<?xml version="1.0" encoding="utf-8" ?>
<local:RequestTemplateCollectionPageBase
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:RequestFiend.Models;assembly=RequestFiend.Models"
    xmlns:local="clr-namespace:RequestFiend.UI"
    x:Class="RequestFiend.UI.RequestTemplateCollectionPage"
    x:DataType="models:RequestTemplateCollectionModel"
    x:TypeArguments="models:RequestTemplateCollectionModel">

    <Grid RowDefinitions="*,Auto" ColumnDefinitions="*" RowSpacing="0">
        <ScrollView Grid.Row="0" Grid.Column="0">
            <VerticalStackLayout>
                <Border>
                    <VerticalStackLayout Style="{StaticResource ElementGroup}">
                        <Label Text="Default url (optional)" Style="{StaticResource FormLabel}"/>

                        <Entry Text="{Binding DefaultUrl.Value}" />

                        <Button Text="Save changes" Clicked="OnUpdateCollectionClicked"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        
        <Label x:Name="SuccessLabel" Style="{StaticResource SuccessMessage}" Grid.Row="1" Grid.Column="0" IsVisible="False" />
    </Grid>
</local:RequestTemplateCollectionPageBase>