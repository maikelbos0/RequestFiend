<?xml version="1.0" encoding="utf-8" ?>
<local:ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:RequestFiend.UI.Models"
    xmlns:local="clr-namespace:RequestFiend.UI"
    x:Class="RequestFiend.UI.MainPage"
    x:DataType="models:MainPageModel"
    x:TypeArguments="models:MainPageModel">

    <ScrollView>
        <VerticalStackLayout>
            <Label Text="Request fiend" Style="{StaticResource Headline}" SemanticProperties.HeadingLevel="Level1"/>

            <Label Text="An open source platform for managing and executing API requests." Style="{StaticResource SubHeadline}" />

            <Border>
                <VerticalStackLayout Style="{StaticResource ElementGroup}">
                    <Label Text="Create a new collection" Style="{StaticResource SubHeadline}" />

                    <Button Text="Choose file location and create" HorizontalOptions="Fill" Clicked="OnCreateNewCollectionClicked"/>
                </VerticalStackLayout>
            </Border>

            <Border>
                <VerticalStackLayout Style="{StaticResource ElementGroup}">
                    <Label Text="Open an existing collection" Style="{StaticResource SubHeadline}" />

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding RecentCollections}" Padding="0" Spacing="5">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:RecentCollectionModel">
                                <Button Text="{Binding Name}" Clicked="OnOpenRecentCollectionClicked" Style="{StaticResource SecondaryButton}" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                        <BindableLayout.EmptyView>
                            <Label Text="No recent items found."/>
                        </BindableLayout.EmptyView>
                    </VerticalStackLayout>
                    
                    <Button Text="Choose collection file to open" HorizontalOptions="Fill" Clicked="OnOpenExistingCollectionClicked"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</local:ContentPage>