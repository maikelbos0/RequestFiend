<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:RequestFiend.UI.Models"
    x:Class="RequestFiend.UI.NewRequestTemplatePage"
    Title="New request"
    x:DataType="models:NewRequestTemplateModel">

    <ScrollView>

        <VerticalStackLayout>

            <Entry Text="{Binding Name, Mode=TwoWay}" Placeholder="Name *" />

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Picker SelectedItem="{Binding Method}" ItemsSource="{Binding Methods}" Grid.Row="0" Grid.Column="0"/>

                <Entry Text="{Binding Url, Mode=TwoWay}" Placeholder="Url" Grid.Row="0" Grid.Column="1"/>

            </Grid>            
            
        </VerticalStackLayout>

    </ScrollView>

</ContentPage>