<?xml version="1.0" encoding="utf-8" ?>
<Grid
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:RequestFiend.UI.Views"
    x:Class="RequestFiend.UI.Views.ValidatableEditor"
    x:Name="Root"
    ColumnDefinitions="*,44">

    <Editor
        x:Name="Editor"
        Text="{Binding x:DataType='viewsValidatableEditorr', Path=Text.Value, Source={x:Reference Root}}"
        IsSpellCheckEnabled="False"
        IsTextPredictionEnabled="False"
        Focused="OnEditorFocused"
        Unfocused="OnEditorUnfocused"
        Style="{Binding x:DataType='views:ValidatableEditor', Path=EditorStyle, Source={x:Reference Root}}"
        Grid.ColumnSpan="2">

        <Editor.Triggers>
            <DataTrigger TargetType="Editor" Binding="{Binding x:DataType='views:ValidatableEditor', Path=Text.HasError, Source={x:Reference Root}}" Value="True">
                <Setter Property="Background" Value="{StaticResource ErrorBackgroundBrush}" />
            </DataTrigger>
            <DataTrigger TargetType="Editor" Binding="{Binding x:DataType='views:ValidatableEditor', Path=Text.IsModifiedWithoutError, Source={x:Reference Root}}" Value="True">
                <Setter Property="Background" Value="{StaticResource ModifiedBackgroundBrush}" />
            </DataTrigger>
        </Editor.Triggers>
    </Editor>

    <Label x:Name="Overlay" Style="{StaticResource EditorOverlay}" IsVisible="False" Grid.ColumnSpan="2">
        <Label.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnOverlayTapped"/>
        </Label.GestureRecognizers>

        <Label.Triggers>
            <DataTrigger TargetType="Label" Binding="{Binding x:DataType='views:ValidatableEditor', Path=Text.HasError, Source={x:Reference Root}}" Value="True">
                <Setter Property="Background" Value="{StaticResource ErrorBackgroundBrush}" />
            </DataTrigger>
            <DataTrigger TargetType="Label" Binding="{Binding x:DataType='views:ValidatableEditor', Path=Text.IsModifiedWithoutError, Source={x:Reference Root}}" Value="True">
                <Setter Property="Background" Value="{StaticResource ModifiedBackgroundBrush}" />
            </DataTrigger>
        </Label.Triggers>
    </Label>

    <Label
        Text="▲"
        TextColor="{x:StaticResource ErrorIcon}"
        IsVisible="{Binding x:DataType='views:ValidatableEditor', Path=Text.HasError, Source={x:Reference Root}}"
        HorizontalTextAlignment="Center"
        FontSize="20"
        Margin="0,5,0,0"
        Grid.Column="1">

        <Label.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnOverlayTapped"/>
        </Label.GestureRecognizers>
    </Label>

    <Label
        Text="●"
        TextColor="{x:StaticResource ModifiedIcon}"
        IsVisible="{Binding x:DataType='views:ValidatableEditor', Path=Text.IsModifiedWithoutError, Source={x:Reference Root}}"
        HorizontalTextAlignment="Center"
        FontSize="28"
        Grid.Column="1">

        <Label.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnOverlayTapped"/>
        </Label.GestureRecognizers>
    </Label>
</Grid>
