<?xml version="1.0" encoding="utf-8" ?>
<views:ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:RequestFiend.Models;assembly=RequestFiend.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:views="clr-namespace:RequestFiend.UI.Views"
    x:Class="RequestFiend.UI.Views.RequestPage"
    x:DataType="models:RequestModel"
    Title="{Binding PageTitle}">

    <ScrollView>
        <VerticalStackLayout>
            <Border>
                <VerticalStackLayout Style="{StaticResource ElementGroup}">
                    <StackLayout Orientation="{Binding StackOrientation}" HorizontalOptions="{Binding StackHorizontalOptions}">
                        <Button Text="Execute" Command="{Binding ExecuteCommand}" IsEnabled="{Binding IsExecuting, Converter={toolkit:IsEqualConverter}, ConverterParameter={x:Boolean False}}"/>

                        <Button Text="Cancel" Command="{Binding CancelExecutionCommand}" IsEnabled="{Binding IsExecuting}"/>

                        <Button Text="Close" Command="{Binding CloseCommand}" Style="{StaticResource DangerButton}"/>
                    </StackLayout>
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding Request, Converter={toolkit:IsNotNullConverter}}">
                <VerticalStackLayout Style="{StaticResource ElementGroup}">
                    <Label Text="Request" Style="{StaticResource SectionHeader}" SemanticProperties.HeadingLevel="Level2"/>

                    <Grid ColumnDefinitions="*,3*" RowDefinitions="*,*">
                        <Label Text="Method" Style="{StaticResource EntryLabel}"/>

                        <Label Text="Url" Style="{StaticResource EntryLabel}" Grid.Column="1"/>

                        <Entry Text="{Binding Request.Method}" IsReadOnly="True" Grid.Row="1" />

                        <Entry Text="{Binding Request.Url}" IsReadOnly="True" Grid.Row="1" Grid.Column="1" />
                    </Grid>

                    <Label Text="Headers" Style="{StaticResource SectionHeader}" SemanticProperties.HeadingLevel="Level2"/>

                    <CollectionView SelectionMode="None" ItemsSource="{Binding Request.Headers}">
                        <CollectionView.Header>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Label Text="Name" Style="{StaticResource EntryLabel}" Margin="10, 0, 0, 0"/>

                                <Label Text="Value" Style="{StaticResource EntryLabel}" Margin="10, 0, 0, 0" Grid.Column="1"/>
                            </Grid>
                        </CollectionView.Header>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:HttpHeaderModel">
                                <Grid ColumnDefinitions="*,*" Style="{StaticResource Table}" ColumnSpacing="10">
                                    <Entry Text="{Binding Name}" Margin="0, 10, 0, 0"  IsReadOnly="True" />

                                    <Entry Text="{Binding Value}" Margin="0, 10, 0, 0" Grid.Column="1" IsReadOnly="True" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding Response, Converter={toolkit:IsNotNullConverter}}">
                <VerticalStackLayout Style="{StaticResource ElementGroup}">
                    <Label Text="Response" Style="{StaticResource SectionHeader}" SemanticProperties.HeadingLevel="Level2"/>

                    <Label Text="Status" Style="{StaticResource EntryLabel}"/>

                    <Entry Text="{Binding Response.Status}" IsReadOnly="True" />

                    <Label Text="Headers" Style="{StaticResource SectionHeader}" SemanticProperties.HeadingLevel="Level2"/>

                    <CollectionView SelectionMode="None" ItemsSource="{Binding Response.Headers}">
                        <CollectionView.Header>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Label Text="Name" Style="{StaticResource EntryLabel}" Margin="10, 0, 0, 0"/>

                                <Label Text="Value" Style="{StaticResource EntryLabel}" Margin="10, 0, 0, 0" Grid.Column="1"/>
                            </Grid>
                        </CollectionView.Header>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:HttpHeaderModel">
                                <Grid ColumnDefinitions="*,*" Style="{StaticResource Table}" ColumnSpacing="10">
                                    <Entry Text="{Binding Name}" Margin="0, 10, 0, 0"  IsReadOnly="True" />

                                    <Entry Text="{Binding Value}" Margin="0, 10, 0, 0" Grid.Column="1" IsReadOnly="True" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding Exception, Converter={toolkit:IsNotNullConverter}}">
                <VerticalStackLayout Style="{StaticResource ElementGroup}">
                    <Label Text="Exception" Style="{StaticResource SectionHeader}" SemanticProperties.HeadingLevel="Level2"/>

                    <Label Text="Type" Style="{StaticResource EntryLabel}"/>

                    <Entry Text="{Binding Exception.Type}" IsReadOnly="True" />

                    <Label Text="Message" Style="{StaticResource EntryLabel}"/>

                    <Entry Text="{Binding Exception.Message}" IsReadOnly="True" />

                    <Label Text="Source" Style="{StaticResource EntryLabel}"/>

                    <Entry Text="{Binding Exception.Source}" IsReadOnly="True" />
                    
                    <Label Text="Stack trace" Style="{StaticResource EntryLabel}"/>

                    <Editor Text="{Binding Exception.StackTrace}" HeightRequest="300" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</views:ContentPage>