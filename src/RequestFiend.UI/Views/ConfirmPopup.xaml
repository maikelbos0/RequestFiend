<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="RequestFiend.UI.Views.ConfirmPopup"
    x:TypeArguments="system:Boolean"
    BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource SecondaryDark}}">

	<VerticalStackLayout>
		<Label x:Name="MessageLabel" />

		<Grid ColumnDefinitions="*,*">
			<Button Text="Ok" Clicked="OnOkClicked" MinimumWidthRequest="-1"/>

			<Button Text="Cancel" Clicked="OnCancelClicked" MinimumWidthRequest="-1" Grid.Column="1"/>
		</Grid>
	</VerticalStackLayout>
</toolkit:Popup>