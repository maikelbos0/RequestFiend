<?xml version="1.0" encoding="utf-8" ?>
<views:ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:RequestFiend.Models;assembly=RequestFiend.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:views="clr-namespace:RequestFiend.UI.Views"
    x:Class="RequestFiend.UI.Views.RequestTemplatePage"
    x:DataType="models:RequestTemplateModel"
    Title="{Binding PageTitle}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:BoolToObjectConverter x:Key="ToggleReferencesTextConverter" TrueObject="hide references" FalseObject="show references"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout>
            <StackLayout Orientation="{Binding StackOrientation}" HorizontalOptions="{Binding StackHorizontalOptions}">
                <Button Text="Execute" Command="{Binding CreateExchangeCommand}" IsEnabled="{Binding HasError, Converter={toolkit:IsEqualConverter}, ConverterParameter={x:Boolean False}}"/>

                <Button Text="Save changes" Command="{Binding UpdateCommand}" IsEnabled="{Binding IsModifiedWithoutError}"/>

                <Button Text="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}"/>
            </StackLayout>

            <Border>
                <VerticalStackLayout Style="{StaticResource ElementGroup}">
                    <Label Text="Name" Style="{StaticResource EntryLabel}"/>

                    <views:ValidatableEntry Text="{Binding Name}"/>

                    <Grid ColumnDefinitions="*,3*" RowDefinitions="*,*">
                        <Label Text="Method" Style="{StaticResource EntryLabel}"/>

                        <Label Style="{StaticResource EntryLabel}" Grid.Column="1">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Url (" />
                                    <Span Style="{StaticResource LinkButton}" Text="edit">
                                        <Span.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ShowUrlPopupCommand}"/>
                                        </Span.GestureRecognizers>
                                    </Span>
                                    <Span Text=")" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <views:ValidatablePicker SelectedItem="{Binding Method}" ItemsSource="{x:Static models:Options.Methods}" Grid.Row="1" />

                        <views:ValidatableEntry Text="{Binding Url}" Grid.Row="1" Grid.Column="1" Collection="{Binding Collection}" />
                    </Grid>

                    <views:NameValuePairCollectionView
                        ItemsSource="{Binding Headers}"
                        NameLabelText="Header name"
                        DeleteButtonText="Delete header"
                        AddButtonText="Add header"
                        Collection="{Binding Collection}"/>

                    <Label Text="Content type" Style="{StaticResource EntryLabel}"/>

                    <views:ValidatablePicker SelectedItem="{Binding ContentType}" ItemsSource="{x:Static models:Options.ContentTypes}"/>

                    <Label Text="Content" Style="{StaticResource EntryLabel}" IsVisible="{Binding UsesUnstructuredContent}"/>

                    <Label Style="{StaticResource EntryLabel}" IsVisible="{Binding UsesStructuredContent}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Content (" />
                                <Span Style="{StaticResource LinkButton}" Text="validate">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ValidateStructuredTextCommand}"/>
                                    </Span.GestureRecognizers>
                                </Span>
                                <Span Text=") (" />
                                <Span Style="{StaticResource LinkButton}" Text="format">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding FormatStructuredTextCommand}"/>
                                    </Span.GestureRecognizers>
                                </Span>
                                <Span Text=")" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <views:ValidatableEditor Text="{Binding StringContent}" Collection="{Binding Collection}" IsVisible="{Binding UsesStringContent}"/>

                    <Grid ColumnDefinitions="*,44" RowDefinitions="*" IsVisible="{Binding UsesFileContent}">
                        <views:ValidatableEntry Text="{Binding FileContent}" Collection="{Binding Collection}" IsVisible="{Binding UsesFileContent}" />

                        <Button 
                            Text="…"
                            Command="{Binding PickFileContentCommand}"
                            Style="{StaticResource SecondaryButton}" 
                            HorizontalOptions="Fill"
                            MinimumWidthRequest="-1"
                            Grid.Column="1" 
                            SemanticProperties.Description="Pick file content" />
                    </Grid>

                    <views:NameValuePairCollectionView
                        ItemsSource="{Binding FormFieldContent}"
                        NameLabelText="Form field name"
                        DeleteButtonText="Delete form field"
                        AddButtonText="Add form field"
                        Collection="{Binding Collection}"
                        IsVisible="{Binding UsesFormDataContent}"/>

                    <CollectionView SelectionMode="None" ItemsSource="{Binding FormFileContent}" IsVisible="{Binding UsesFormDataContent}">
                        <CollectionView.Header>
                            <Grid ColumnDefinitions="*,*,44,44" IsVisible="{Binding FormFileContent.HasItems}">
                                <Label Text="Form file name" Style="{StaticResource EntryLabel}" Margin="10, 0, 0, -5"/>

                                <Label Text="Value" Style="{StaticResource EntryLabel}" Margin="10, 0, 0, -5" Grid.Column="1"/>
                            </Grid>
                        </CollectionView.Header>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:NameValuePairModel">
                                <Grid ColumnDefinitions="*,*,44,44" Style="{StaticResource Table}">
                                    <views:ValidatableEntry
                                        Text="{Binding Name}"
                                        Margin="0, 10, 0, 0"
                                        Collection="{Binding x:DataType='models:RequestTemplateModel', Path=Collection, Source={RelativeSource AncestorType={x:Type models:RequestTemplateModel}}}"/>

                                    <views:ValidatableEntry
                                        Text="{Binding Value}"
                                        Margin="0, 10, 0, 0"
                                        Collection="{Binding x:DataType='models:RequestTemplateModel', Path=Collection, Source={RelativeSource AncestorType={x:Type models:RequestTemplateModel}}}"
                                        Grid.Column="1"/>

                                    <Button 
                                        Text="…"
                                        Command="{Binding x:DataType='models:RequestTemplateModel', Path=PickFormFileContentCommand, Source={RelativeSource AncestorType={x:Type models:RequestTemplateModel}}}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0, 10, 0, 0"
                                        HorizontalOptions="Fill"
                                        MinimumWidthRequest="-1"
                                        Grid.Column="2"
                                        SemanticProperties.Description="Pick form file" />
                                    
                                    <Button 
                                        Text="✕"
                                        Command="{Binding x:DataType='models:RequestTemplateModel', Path=FormFileContent.RemoveCommand, Source={RelativeSource AncestorType={x:Type models:RequestTemplateModel}}}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource SecondaryButton}" 
                                        Margin="0, 10, 0, 0"
                                        HorizontalOptions="Fill"
                                        MinimumWidthRequest="-1"
                                        Grid.Column="3"
                                        SemanticProperties.Description="Delete form file" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.Footer>
                            <Button 
                                Text="Add form file"
                                Command="{Binding x:DataType='models:RequestTemplateModel', Path=FormFileContent.AddCommand, Source={RelativeSource AncestorType={x:Type models:RequestTemplateModel}}}"
                                Style="{x:StaticResource SecondaryButton}"
                                Margin="0, 10, 0, 0"
                                HorizontalOptions="Fill"/>
                        </CollectionView.Footer>
                    </CollectionView>

                    <Grid ColumnDefinitions="Auto, *" IsVisible="{Binding UsesContent}">
                        <Switch IsToggled="{Binding HasManualContentTypeHeader.Value}"/>

                        <Label Text="Has manually added content type header" Grid.Column="1" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleHasManualContentTypeHeaderCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <Label Style="{StaticResource EntryLabel}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Pre-exchange script (" />
                                <Span Style="{StaticResource LinkButton}" Text="{Binding PreExchangeScript.ShowReferences, Converter={StaticResource ToggleReferencesTextConverter}}">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding PreExchangeScript.ToggleShowReferencesCommand}"/>
                                    </Span.GestureRecognizers>
                                </Span>
                                <Span Text=")" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <views:ValidatableEditor Text="{Binding PreExchangeScript.References}" IsVisible="{Binding PreExchangeScript.ShowReferences}" EditorStyle="{StaticResource SmallEditor}"/>

                    <views:ValidatableEditor Text="{Binding PreExchangeScript.Code}"/>

                    <Label Style="{StaticResource EntryLabel}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Post-exchange script (" />
                                <Span Style="{StaticResource LinkButton}" Text="{Binding PostExchangeScript.ShowReferences, Converter={StaticResource ToggleReferencesTextConverter}}">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding PostExchangeScript.ToggleShowReferencesCommand}"/>
                                    </Span.GestureRecognizers>
                                </Span>
                                <Span Text=")" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <views:ValidatableEditor Text="{Binding PostExchangeScript.References}" IsVisible="{Binding PostExchangeScript.ShowReferences}" EditorStyle="{StaticResource SmallEditor}"/>

                    <views:ValidatableEditor Text="{Binding PostExchangeScript.Code}"/>

                    <Label Style="{StaticResource EntryLabel}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="On-exception script (" />
                                <Span Style="{StaticResource LinkButton}" Text="{Binding OnExceptionScript.ShowReferences, Converter={StaticResource ToggleReferencesTextConverter}}">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OnExceptionScript.ToggleShowReferencesCommand}"/>
                                    </Span.GestureRecognizers>
                                </Span>
                                <Span Text=")" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <views:ValidatableEditor Text="{Binding OnExceptionScript.References}" IsVisible="{Binding OnExceptionScript.ShowReferences}" EditorStyle="{StaticResource SmallEditor}"/>

                    <views:ValidatableEditor Text="{Binding OnExceptionScript.Code}"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</views:ContentPage>