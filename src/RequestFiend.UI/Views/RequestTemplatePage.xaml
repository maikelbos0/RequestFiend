<?xml version="1.0" encoding="utf-8" ?>
<views:ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:RequestFiend.Models;assembly=RequestFiend.Models"
    xmlns:views="clr-namespace:RequestFiend.UI.Views"
    xmlns:core="clr-namespace:RequestFiend.Core;assembly=RequestFiend.Core"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="RequestFiend.UI.Views.RequestTemplatePage"
    x:DataType="models:RequestTemplateModel"
    Title="{Binding PageTitle}">

    <ScrollView>
        <VerticalStackLayout>
            <Border>
                <VerticalStackLayout Style="{StaticResource ElementGroup}">
                    <StackLayout Orientation="{Binding StackOrientation}" HorizontalOptions="{Binding StackHorizontalOptions}">
                        <Button Text="Execute" Command="{Binding ExecuteCommand}" IsEnabled="{Binding HasError, Converter={toolkit:IsEqualConverter}, ConverterParameter={x:Boolean False}}"/>
                        
                        <Button Text="Save changes" Command="{Binding UpdateCommand}" IsEnabled="{Binding IsModifiedWithoutError}"/>

                        <Button Text="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}"/>
                    </StackLayout>

                    <Label Text="Name" Style="{StaticResource EntryLabel}"/>

                    <views:ValidatableEntry Text="{Binding Name}"/>

                    <Grid ColumnDefinitions="*,3*">
                        <Label Text="Method" Style="{StaticResource EntryLabel}"/>

                        <Label Text="Url" Style="{StaticResource EntryLabel}" Grid.Column="1"/>

                        <views:ValidatablePicker SelectedItem="{Binding Method}" ItemsSource="{x:Static models:Options.Methods}" Grid.Row="1" />

                        <views:ValidatableEntry Text="{Binding Url}" Grid.Row="1" Grid.Column="1" />
                    </Grid>

                    <Label Text="Headers" Style="{StaticResource SectionHeader}" SemanticProperties.HeadingLevel="Level2"/>

                    <views:NameValuePairCollectionView ItemsSource="{Binding Headers}" DeleteButtonText="Delete header" AddButtonText="Add header"/>

                    <Label Text="Body" Style="{StaticResource SectionHeader}" SemanticProperties.HeadingLevel="Level2"/>

                    <Label Text="Content type" Style="{StaticResource EntryLabel}"/>

                    <views:ValidatablePicker SelectedItem="{Binding ContentType}" ItemsSource="{x:Static models:Options.ContentTypes}"/>

                    <StackLayout Orientation="{Binding StackOrientation}" HorizontalOptions="{Binding StackHorizontalOptions}" IsVisible="{Binding UsesJsonContent}">
                        <Button Text="Validate JSON" Command="{Binding ValidateJsonCommand}"/>

                        <Button Text="Format JSON" Command="{Binding FormatJsonCommand}"/>
                    </StackLayout>

                    <Label Text="Content" Style="{StaticResource EntryLabel}" IsVisible="{Binding UsesStringContent}"/>

                    <views:ValidatableContentEditor Text="{Binding StringContent}" IsVisible="{Binding UsesStringContent}"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</views:ContentPage>