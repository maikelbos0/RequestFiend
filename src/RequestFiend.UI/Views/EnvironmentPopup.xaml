<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:RequestFiend.Models;assembly=RequestFiend.Models"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:views="clr-namespace:RequestFiend.UI.Views"
    x:Class="RequestFiend.UI.Views.EnvironmentPopup"
    x:DataType="models:EnvironmentModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource SecondaryDark}}">

    <ScrollView>
        <VerticalStackLayout>
            <Label Text="{Binding PageTitle}" Style="{StaticResource SectionHeader}" SemanticProperties.HeadingLevel="Level2"/>

            <Button Text="Save and close" Command="{Binding UpdateCommand}" IsEnabled="{Binding IsModifiedWithoutError}"/>

            <views:NameValuePairCollectionView
                ItemsSource="{Binding Variables}"
                NameLabelText="Variable name"
                DeleteButtonText="Delete variable"
                AddButtonText="Add variable"/>
        </VerticalStackLayout>
    </ScrollView>
</toolkit:Popup>