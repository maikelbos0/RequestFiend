<?xml version="1.0" encoding="utf-8" ?>
<views:RequestTemplateCollectionPageBase
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:RequestFiend.Models;assembly=RequestFiend.Models"
    xmlns:views="clr-namespace:RequestFiend.UI.Views"
    x:Class="RequestFiend.UI.Views.RequestTemplateCollectionPage"
    x:DataType="models:RequestTemplateCollectionModel"
    x:TypeArguments="models:RequestTemplateCollectionModel">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <views:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto" RowSpacing="0">
        <ScrollView>
            <VerticalStackLayout>
                <Border>
                    <VerticalStackLayout Style="{StaticResource ElementGroup}">
                        <StackLayout Orientation="{Binding StackOrientation}" HorizontalOptions="{Binding StackHorizontalOptions}">
                            <Button Text="Save changes" Clicked="OnUpdateCollectionClicked"/>
                        </StackLayout>

                        <Label Text="Default url (optional)" Style="{StaticResource EntryLabel}"/>

                        <Entry Text="{Binding DefaultUrl.Value}" />

                        <Label Text="Default headers" Style="{StaticResource SectionHeader}" SemanticProperties.HeadingLevel="Level2"/>

                        <views:NameValuePairCollection ItemsSource="{Binding DefaultHeaders}" DeleteButtonText="Delete default header" AddButtonText="Add default header"/>
                        
                        <Label Text="Variables" Style="{StaticResource SectionHeader}" SemanticProperties.HeadingLevel="Level2"/>

                        <views:NameValuePairCollection ItemsSource="{Binding Variables}" DeleteButtonText="Delete variable" AddButtonText="Add variable"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <views:Message x:Name="SuccessMessage" Grid.Row="1"/>
    </Grid>
</views:RequestTemplateCollectionPageBase>